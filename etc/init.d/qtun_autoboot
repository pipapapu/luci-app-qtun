#!/bin/sh /etc/rc.common

START=120
STOP=10

USE_PROCD=1

WAIT_MAX=300
WAIT_STEP=3

has_wan_ip() {
    ip -4 route show default 2>/dev/null | grep -q " dev " || return 1

    DEV="$(ip route show default 2>/dev/null | awk '
        /default/ {
            for (i=1; i<=NF; i++) {
                if ($i == "dev") {
                    print $(i+1)
                    exit
                }
            }
        }
    ')"

    [ -n "$DEV" ] || return 1

    ip -4 addr show dev "$DEV" 2>/dev/null | \
        awk '/inet / {print $2}' | \
        grep -vqE '^(127\.|169\.254\.)'
}

wait_wan_ip() {
    local i=0

    logger -t QTUN "Waiting WAN/default interface IP..."

    while [ "$i" -lt "$WAIT_MAX" ]; do
        if has_wan_ip; then
            logger -t QTUN "WAN/default interface has IP"
            return 0
        fi

        sleep "$WAIT_STEP"
        i=$((i + WAIT_STEP))
    done

    logger -t QTUN "WAN/default interface IP not ready, starting QTUN anyway"
    return 1
}

start_service() {
    logger -t QTUN "Boot start requested"

    (
        wait_wan_ip
        /etc/qtun/action/qtun.sh boot >/dev/null 2>&1
    ) &
}

stop_service() {
    logger -t QTUN "Stop requested"
    /etc/qtun/action/qtun.sh stop >/dev/null 2>&1
}

restart_service() {
    logger -t QTUN "Restart requested"

    (
        wait_wan_ip
        /etc/qtun/action/qtun.sh restart >/dev/null 2>&1
    ) &
}
